/* ============================================
   Agent Overview Stylesheet
   ============================================ */

QFrame#AgentOverview {
  background-color: #141e31;
  border: 1px solid #273b4f;
  border-radius: 8px;
}

QFrame#AgentOverview > QFrame, 
QFrame#AgentOverview > QLabel,
QLabel {
  background-color: #141e31;
}

QLabel#AgentOverviewHeader {
  color: #ffffff;
  font-weight: bold;
  font-size: 14px;
  margin-bottom: 8px;
}

QLabel#AgentOverviewSummary {
  color: #9fadc4;
}

QFrame#AgentCard {
  background-color: #141e31;
  border: 1px solid #364153;
  border-radius: 4px;
  padding: 6px;
}

QFrame#AgentCard QLabel {
  color: #e0e0e0;
}